---
import SiteLayout from "../layout/SiteLayout.astro";
---

<SiteLayout title="Vladislav Goian - Front-end developer based in London">
    <!-- ABOUT ME  -->
    <div
        class="animate__animated animate__fadeInUp animate__slow relative mt-14 md:mt-24 z-10 ml-5 md:ml-0 md:grid md:grid-cols-8"
    >
        <div class="md:col-start-2 md:col-span-5 relative">
            <div class="absolute -right-30 top-10 h-96 w-96 bg-primary rounded-full filter blur-2xl opacity-40 animate-blob hidden md:block -z-10"></div>
            <h1 class="font-ptSerif text-3xl md:text-7xl md:leading-[1.3] md:max-w-3xl">
                Hi, I'm Vladislav.<br />A front-end developer based in London.
            </h1>
            <p class="text-2xl mt-6 font-ptSans leading-10">
                Currently working as Web Developer at <a class="underline" href="http://tmpb2b.com">TMP.</a>
            </p>
        </div>
    </div>
    <!-- PROJECTS -->
    <section
        class="animate__animated animate__fadeInUp grid md:grid-cols-8 m-5 mt-32 md:mt-56 z-0"
    >
        <div class="font-ptSerif text-7xl md:col-start-2">
            <a href="/projects">
                <h1 class="hover:text-green-500">Projects</h1></a
            >
        </div>
        <div
            class="md:col-start-2 col-span-6 max-h-full overflow-hidden mt-20 font-ptSans mr-5 border-b border-gray-400 border-opacity-40"
        >
            <div class="md:m-5">
                <div class="overflow-hidden">
                    <a href="/projects/signalsfromtheshore">
                        <img
                            src="/img/signals-from-the-shore-1.png"
                            loading="lazy"
                            alt="Signals from the Shore"
                            class="object-cover w-full h-full transform transition duration-700 hover:scale-105"
                        />
                    </a>
                </div>
                <h2
                    class="md:mt-16 mt-8 text-3xl md:text-6xl font-ptSerif italic hover:text-green-500"
                >
                    <a href="/projects/signalsfromtheshore">Signals from the Shore</a>
                </h2>
                <div
                    class="flex items-center mt-5 text-lg md:text-2xl text-gray-500 mb-16"
                >
                    <a
                        href="https://www.signalsfromtheshore.co.uk/"
                        class="inline-block mr-10 hover:text-green-500"
                        >Visit website</a
                    >
                </div>
            </div>
        </div>
        <div
            class="md:col-start-2 col-span-6 max-h-full overflow-hidden mt-8 md:mt-40 font-ptSans mr-5 border-b border-gray-400 border-opacity-40"
        >
            <div class="md:m-5">
                <div class="overflow-hidden">
                    <a href="/projects/jato">
                        <img
                            src="/img/jato-1.png"
                            loading="lazy"
                            alt="Jato"
                            class="object-cover w-full h-full transform transition duration-700 hover:scale-105"
                        />
                    </a>
                </div>
                <h2
                    class="md:mt-16 mt-8 text-3xl md:text-6xl font-ptSerif italic hover:text-green-500"
                >
                    <a href="/projects/jato">Jato</a>
                </h2>
                <div
                    class="flex items-center mt-5 text-lg md:text-2xl text-gray-500 mb-16"
                >
                    <a
                        href="https://jato.com"
                        class="inline-block mr-10 hover:text-green-500"
                        >Visit website</a
                    >
                </div>
            </div>
        </div>
        <div
            class="md:col-start-2 col-span-6 max-h-full overflow-hidden mt-8 md:mt-40 font-ptSans mr-5 border-b border-gray-400 border-opacity-40"
        >
            <div class="md:m-5">
                <div class="overflow-hidden">
                    <a href="/projects/theatre" class="">
                        <img
                            src="/img/Chernivtsi university.webp"
                            loading="lazy"
                            alt="Theatre"
                            class="object-cover w-full h-full transform transition duration-700 hover:scale-105"
                        />
                    </a>
                </div>
                <h2
                    class="md:mt-16 mt-8 text-3xl md:text-6xl font-ptSerif italic hover:text-green-500"
                >
                    <a href="/projects/theatre">Chernivtsi theatre</a>
                </h2>
                <div
                    class="flex items-center mt-5 text-lg md:text-2xl text-gray-500 mb-16"
                >
                    <a
                        href="https://chernivtsi-theatre.vercel.app/"
                        class="inline-block mr-10 hover:text-green-500"
                        >Visit website</a
                    >
                    <a
                        href="https://github.com/vladislav-gg/chernivtsi_app"
                        class="inline-block hover:text-green-500">Github</a
                    >
                    <span class="mt-2 flex items-center"></span>
                </div>
            </div>
        </div>
        <div
            class="md:col-start-2 col-span-6 max-h-full overflow-hidden mt-8 md:mt-40 font-ptSans mr-5"
        >
            <div class="md:m-5">
                <div class="overflow-hidden">
                    <a href="/projects/university" class="">
                        <img
                            src="/img/chernivtsi-university4.webp"
                            loading="lazy"
                            alt="University"
                            class="object-cover w-full h-full transform transition duration-700 hover:scale-105"
                        />
                    </a>
                </div>
                <h2
                    class="mt-16 text-3xl md:text-6xl font-ptSerif italic hover:text-green-500"
                >
                    <a href="/projects/university">Chernivtsi university</a>
                </h2>
                <div
                    class="flex items-center mt-5 text-lg md:text-2xl text-gray-500 mb-4 md:mb-16"
                >
                    <a
                        href="https://chernivtsiuniversity.vercel.app/"
                        class="inline-block mr-10 hover:text-green-500"
                        >Visit website</a
                    >
                    <a
                        href="https://github.com/vladislav-gg/chernivtsi_university"
                        class="inline-block hover:text-green-500">Github</a
                    >
                    <span class="mt-2 flex items-center"></span>
                </div>
            </div>
        </div>
    </section>
</SiteLayout>
