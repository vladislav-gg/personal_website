---
import SiteLayout from "../../layout/SiteLayout.astro";
---

<SiteLayout title="Chernivtsi university website project">
    <div class="w-full flex justify-center mt-16 md:mt-32">
        <div
            class="wrapper flex flex-col justify-center animate__animated animate__fadeInUp animate__slow"
        >
            <div class="max-w-7xl flex flex-col md:flex-row md:justify-between">
                <div class="left-container ml-5 md:ml-0">
                    <h2
                        class="font-semibold text-gray-900 text-3xl font-ptSerif hover:text-gray-600 underline"
                    >
                        <a href="https://chernivtsiuniversity.vercel.app/"
                            >Chernivtsi university website</a
                        >
                    </h2>
                    <p class="w-80 text-2xl mt-3">
                        A website for my hometown university.
                    </p>
                </div>
                <div
                    class="right-container max-w-xl font-ptSans ml-5 md:ml-24 text-xl mt-7 md:mt-0"
                >
                    <p class="">
                        Developed a fully responsive website for my hometown
                        university with Next.js, CSS, HTML, Firebase
                        authentication and Strapi CMS as backend. <br />
                        <p class="mt-3">
                            Link to <a
                                href="https://github.com/vladislav-gg/chernivtsi_university"
                                class="text-blue-800">github.</a
                            >
                        </p>
                        <p class="mt-3">
                            Techonolgies and libraries used:
                            <ul class="list-disc list-inside ml-1">
                                <li class="mt-1">Next.js</li>
                                <li class="mt-1">Swiper</li>
                                <li class="mt-1">Framer motion</li>
                                <li class="mt-1">Firebase auth</li>
                            </ul>
                        </p>
                    </p>
                </div>
            </div>

            <div class="images max-w-7xl flex">
                <div class="max-w-7xl overflow-hidden mt-16">
                    <img
                        class="w-full object-cover"
                        src="/src/img/chernivtsi-university8.webp"
                    />
                </div>
            </div>
            <div class="images max-w-7xl flex">
                <div class="max-w-7xl overflow-hidden mt-12">
                    <img
                        class="w-full object-cover"
                        src="/src/img/chernivtsi-university1.webp"
                    />
                </div>
            </div>
            <div class="images max-w-7xl flex">
                <div class="max-w-7xl overflow-hidden mt-12">
                    <img
                        class="w-full object-cover"
                        src="/src/img/chernivtsi-university9.webp"
                    />
                </div>
            </div>
        </div>
    </div>
</SiteLayout>
