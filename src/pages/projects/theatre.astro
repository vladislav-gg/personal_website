---
import SiteLayout from "../../layout/SiteLayout.astro";
---

<SiteLayout title="Chernivtsi theatre website project">
    <div class="w-full flex justify-center mt-16 md:mt-32">
        <div
            class="wrapper flex flex-col justify-center animate__animated animate__fadeIn animate__slower"
        >
            <div class="max-w-7xl flex flex-col md:flex-row md:justify-between">
                <div class="left-container ml-5 md:ml-0">
                    <h2
                        class="font-semibold text-gray-900 text-3xl font-ptSerif hover:text-gray-600 underline"
                    >
                        <a href="https://chernivtsi-theatre.vercel.app/"
                            >Chernivtsi theatre website</a
                        >
                    </h2>
                    <p class="w-80 text-2xl mt-3">
                        A website for my hometown theatre.
                    </p>
                </div>
                <div
                    class="right-container max-w-xl font-ptSans ml-5 md:ml-24 text-xl mt-7 md:mt-0"
                >
                    <p class="">
                        Designed and developed a website for my hometown theatre
                        using Next.js. The project has google authentication, an
                        integrated Stripe payment method, email subscription
                        form which is linked to Mailchimp API. The website is
                        fully responsive and styled with TailwindCSS.<br />
                        <div class="mt-2">
                            <p class="mt-3">
                                Link to <a
                                    href="https://github.com/vladislav-gg/chernivtsi_app"
                                    class="text-blue-800">github.</a
                                >
                            </p>
                        </div>
                        <p class="mt-6">
                            Techonolgies and libraries used:
                            <ul class="list-disc list-inside ml-1">
                                <li class="mt-1">Next.js</li>
                                <li class="mt-1">Stripe API</li>
                                <li class="mt-1">Mailchimp</li>
                                <li class="mt-1">TailwindCSS</li>
                                <li class="mt-1">Keen-slider</li>
                                <li class="mt-1">Next-auth</li>
                            </ul>
                        </p>
                    </p>
                </div>
            </div>

            <div class="images max-w-7xl flex">
                <div class="max-w-7xl overflow-hidden mt-16">
                    <img
                        class="w-full object-cover"
                        src="/img/chernivtsi-theatre1.webp"
                    />
                </div>
            </div>
            <div class="images max-w-7xl flex">
                <div class="max-w-7xl overflow-hidden mt-12">
                    <img
                        class="w-full object-cover"
                        src="/img/chernivtsi-theatre3.webp"
                    />
                </div>
            </div>
            <div class="images max-w-7xl flex">
                <div class="max-w-7xl overflow-hidden mt-12">
                    <img
                        class="w-full object-cover"
                        src="/img/chernivtsi-theatre2.webp"
                    />
                </div>
            </div>
            <div class="images max-w-7xl flex">
                <div class="max-w-7xl overflow-hidden mt-12 mb-12">
                    <img
                        class="w-full object-cover"
                        src="/img/chernivtsi-theatre4.webp"
                    />
                </div>
            </div>
        </div>
    </div>
</SiteLayout>
