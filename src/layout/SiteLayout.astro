---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import '../styles/styles.css'
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta
      name="description"
      content="My name is Vladislav and I'm a web developer, based in London."
    />
    <link rel="stylesheet" href="/src/styles/styles.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=PT+Sans:ital,wght@0,400;0,700;1,400&family=PT+Serif:ital,wght@0,400;0,700;1,400;1,700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/img/my-favicon.png" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"
    />
  </head>
  <body class="h-full bg-gray-100 w-full font-ptSans">
    <div >
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
    <script>
      import "../js/index.js";
    </script>
  </body>
</html>
